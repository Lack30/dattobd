        <mxCell id="s5e" value="• 更新 /backup/sda1-full.img 中对应的块" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="step5">
          <mxGeometry x="20" y="120" width="460" height="20" as="geometry" />
        </mxCell>
        <mxCell id="step6" value="步骤 6: 清理并循环" style="swimlane;startSize=30;horizontal=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="760" width="500" height="100" as="geometry" />
        </mxCell>
        <mxCell id="s6a" value="$ rm /.datto" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=monospace;" vertex="1" parent="step6">
