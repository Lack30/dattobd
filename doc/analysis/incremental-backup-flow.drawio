        <mxCell id="s4e" value="• seqid 递增" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="step4">
          <mxGeometry x="20" y="120" width="460" height="20" as="geometry" />
        </mxCell>
        <mxCell id="step5" value="步骤 5: 应用增量更新" style="swimlane;startSize=30;horizontal=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="500" height="140" as="geometry" />
        </mxCell>
        <mxCell id="s5a" value="$ update-img /dev/datto0 /.datto /backup/sda1-full.img" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=monospace;" vertex="1" parent="step5">
