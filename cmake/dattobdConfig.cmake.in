#
# dattobdConfig.cmake.in - CMake package configuration file
#

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

include("${CMAKE_CURRENT_LIST_DIR}/dattobdTargets.cmake")

check_required_components(dattobd)

set(DATTOBD_VERSION @PROJECT_VERSION@)
set(DATTOBD_KERNEL_VERSION @KERNEL_VERSION@)
set(DATTOBD_KERNEL_SOURCE @KERNEL_SOURCE_DIR@)

if(NOT TARGET dattobd::dattobd)
    add_library(dattobd::dattobd ALIAS dattobd)
endif()

message(STATUS "Found dattobd: ${CMAKE_CURRENT_LIST_DIR} (version ${DATTOBD_VERSION})")
